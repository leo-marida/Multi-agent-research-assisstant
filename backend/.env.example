# ── AI Keys ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
TAVILY_API_KEY=tvly-dev-...

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker (default)
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/nexus
DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:password@localhost:5432/nexus

# Supabase (production) — get from: Project Settings → Database → Connection string
# DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# DATABASE_URL_ASYNC=postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres?ssl=require

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://your-app.vercel.app
